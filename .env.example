# Server
PORT=3000
REQUEST_TIMEOUT_MS=30000

# Cube.dev local semantic layer (NO XMLA)
DATABASE_URL="sqlserver://localhost:1433;database=chatbot;user=SA;password=YourStrong@Passw0rd;encrypt=true;trustServerCertificate=true"
CUBEJS_PORT=4000
CUBEJS_API_SECRET=change_me_super_secret
CUBEJS_DB_HOST=sqlserver-host
CUBEJS_DB_PORT=1433
CUBEJS_DB_NAME=database_name
CUBEJS_DB_USER=db_user
CUBEJS_DB_PASS=db_password
CUBEJS_DB_SSL=false
CUBEJS_DEFAULT_SQL_TABLE=dbo.your_fact_table
CUBEJS_SCHEMA_PATH=schema
CUBEJS_API_BASE_URL=http://localhost:4000/cubejs-api/v1

# XMLA source (msmdpump.dll) for auto-generation
XMLA_ENDPOINT=http://192.168.100.50:8080/OLAP/msmdpump.dll
XMLA_USER=domain\\user
XMLA_PWD=your_password
# Optional: restrict discovery to one catalog
XMLA_CATALOG=

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=your_pinecone_index_name
PINECONE_NAMESPACE=cube-metadata

# Azure AI Foundry / Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-deployment-name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small-deployment-name

# Azure AI Projects (Agent existente)
AZURE_EXISTING_AGENT_ID=agent-name:1
AZURE_EXISTING_AIPROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project-name
# Opcional, solo si aparece error de tenant mismatch
AZURE_TENANT_ID=your-tenant-id
