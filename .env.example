# ── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
REQUEST_TIMEOUT_MS=30000

# ── CORS ─────────────────────────────────────────────────────────────────
# Orígenes permitidos para el frontend (separa por comas).
# Usa '*' para permitir cualquier origen (dev).
CORS_ALLOWED_ORIGINS=*

# ── Autenticación API Launcher ───────────────────────────────────────────────
API_LAUNCHER_ENDPOINT=https://apilaunch.ideauto.com/api/v1
PRODUCT_ID=your-product-guid
# Poner "true" SOLO en desarrollo local para omitir autenticación
BYPASS_AUTH=false
# Token de prueba (fallback cuando no hay header Authorization). Quitar en producción.
DEV_TEST_TOKEN=

# ── Base de datos SQL Server (persistencia de chats y catálogo) ──────────────
DB_HOST=your-sqlserver-host
DB_PORT=1433
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-database-name
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# ── XMLA / SSAS (fuente de datos OLAP) ──────────────────────────────────────
XMLA_ENDPOINT=http://your-ssas-server/OLAP/msmdpump.dll
XMLA_USER=domain\\user
XMLA_PWD=your_ssas_password
# Catálogo por defecto (opcional)
# XMLA_CATALOG=

# ── Azure AI Projects ────────────────────────────────────────────────────────
AZURE_EXISTING_AIPROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_TENANT_ID=your-tenant-id

# Agente 1 — Planificador / Intérprete NLU
AZURE_PLANNER_AGENT_ID=your-planner-agent-id

# Agente 2 — Worker / Redactor de respuestas
AZURE_WORKER_AGENT_ID=your-worker-agent-id

# ── Autenticación Azure — Service Principal ──────────────────────────────────
# OBLIGATORIO en servidores on-premise (Windows/Linux) sin az CLI ni VS Code.
# Pasos para obtenerlo:
#   1. Azure Portal → Azure Active Directory → App Registrations → New registration
#   2. Copia el "Application (client) ID" → AZURE_CLIENT_ID
#   3. En el App Registration → Certificates & secrets → New client secret → AZURE_CLIENT_SECRET
#   4. En el recurso Azure AI Projects → IAM → Add role assignment:
#      rol "Azure AI Developer" al Service Principal creado
# Si estas variables NO están, se usa DefaultAzureCredential (az CLI, VS Code…)
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret-value

# ── Cube.js (schema path) ────────────────────────────────────────────────────
CUBEJS_SCHEMA_PATH=schema
