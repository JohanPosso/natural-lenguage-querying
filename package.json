{
  "name": "natural-language-cube-query",
  "version": "1.0.0",
  "description": "Node.js backend for semantic query orchestration over Cube.dev with Pinecone and Azure OpenAI.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test-mdx-bridge": "ts-node src/scripts/testMdxBridge.ts",
    "test-cube-client": "ts-node src/scripts/testCubeClient.ts",
    "test-existing-agent": "ts-node src/scripts/testExistingAgent.ts",
    "test-mssql-connection": "ts-node src/scripts/testMssqlConnection.ts",
    "sync-catalog": "ts-node src/scripts/syncCatalog.ts",
    "export-catalog": "ts-node src/scripts/exportCatalogJson.ts",
    "export-catalog-fast": "ts-node src/scripts/exportCatalogJson.ts --skip-members"
  },
  "dependencies": {
    "@azure/ai-projects": "^2.0.1",
    "@azure/identity": "^4.13.0",
    "@azure/openai": "^2.0.0",
    "@babel/runtime": "^7.28.6",
    "axios": "^1.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.2.0",
    "openai": "^4.80.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mssql": "^9.1.9",
    "@types/node": "^20.14.10",
    "@types/xml2js": "^0.4.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
